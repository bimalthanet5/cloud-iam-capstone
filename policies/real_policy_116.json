{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadFromDropZone",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:HeadObject"
      ],
      "Resource": "arn:aws:s3:::honeyscan-dropzone-585098516938/*"
    },
    {
      "Sid": "StartStepFunction",
      "Effect": "Allow",
      "Action": "states:StartExecution",
      "Resource": "arn:aws:states:us-east-1:585098516938:stateMachine:HoneyScanStateMachine"
    },
    {
      "Sid": "BasicLambdaLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:*:*:*"
    }
  ]
}