{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowS3ObjectOpsForLosthole",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::losthole-demo-media-chanwitkamjadpai",
        "arn:aws:s3:::losthole-demo-media-chanwitkamjadpai/*"
      ]
    },
    {
      "Sid": "AllowDynamoDBOpsForLosthole",
      "Effect": "Allow",
      "Action": [
        "dynamodb:ListTables",
        "dynamodb:DescribeTable",
        "dynamodb:CreateTable",
        "dynamodb:PutItem",
        "dynamodb:GetItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Query",
        "dynamodb:Scan",
        "dynamodb:BatchWriteItem",
        "dynamodb:BatchGetItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:ap-southeast-2:507660350538:table/*"
      ]
    }
  ]
}