{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BasicCloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:us-west-2:675138611834:log-group:/aws/lambda/ChargeScrub-Processor:*"
    }
  ]
}